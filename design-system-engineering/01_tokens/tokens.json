{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Dupoin design token index. Color tokens are maintained in tokens.color.json; runtime non-color tokens are maintained in src/theme/tokens.ts and mapped here for governance.",
  "version": "2.0.0",
  "sources": {
    "color": "design-system-engineering/01_tokens/tokens.color.json",
    "modeMatrix": "design-system-engineering/01_tokens/token-mode.matrix.json",
    "runtime": "src/theme/tokens.ts",
    "documentation": "design-system/01-tokens"
  },
  "tokenLayers": {
    "L1": {
      "name": "primitive",
      "pageDirectUse": false,
      "description": "Raw color ramps and base numeric values."
    },
    "L2": {
      "name": "semantic",
      "pageDirectUse": true,
      "description": "Surface, text, border, status, market, chart, overlay, and brand aliases."
    },
    "L3": {
      "name": "component",
      "pageDirectUse": false,
      "description": "Component-level bindings consumed through component APIs."
    }
  },
  "families": [
    "color",
    "spacing",
    "radius",
    "shadow",
    "typography",
    "size",
    "lineWidth",
    "motion",
    "zIndex",
    "breakpoint"
  ],
  "titleRoleMap": {
    "page": "typography.displayXl",
    "pageCompact": "typography.displayLg",
    "dialog": "typography.sheetTitle",
    "sheet": "typography.sheetTitle",
    "card": "typography.titleMd",
    "section": "typography.titleMd",
    "list": "typography.caption",
    "listItem": "typography.titleMd",
    "tabs": "typography.caption",
    "bottomTabs": "typography.microLabel"
  },
  "bodyRoleMap": {
    "primary": "typography.bodyMd",
    "secondary": "typography.bodySm",
    "dense": "typography.bodySm",
    "prominent": "typography.bodyLg"
  },
  "labelRoleMap": {
    "default": "typography.caption",
    "helper": "typography.captionSm",
    "metadata": "typography.captionSm",
    "field": "typography.bodySm",
    "control": "typography.caption",
    "status": "typography.microLabel",
    "minimum": "typography.microLabel"
  },
  "minimumTextRule": {
    "minFontSize": 12,
    "allowedRoles": [
      "label.minimum",
      "label.status",
      "title.bottomTabs"
    ]
  },
  "requiredModes": [
    "darkTerminal"
  ],
  "releaseStatus": "active"
}
