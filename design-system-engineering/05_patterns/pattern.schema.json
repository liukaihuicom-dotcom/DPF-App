{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pattern Registry Schema",
  "type": "object",
  "required": ["version", "source", "patterns"],
  "properties": {
    "version": { "type": "string" },
    "source": { "type": "string" },
    "patterns": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["documentation", "platforms", "requiredStructure", "recommendedComponents", "requiredStates", "forbidden"],
        "properties": {
          "documentation": { "type": "string" },
          "platforms": {
            "type": "array",
            "items": { "type": "string", "enum": ["app", "h5", "web", "admin"] },
            "minItems": 1
          },
          "requiredStructure": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "recommendedComponents": { "type": "array", "items": { "type": "string" } },
          "requiredStates": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "forbidden": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        }
      }
    }
  }
}
