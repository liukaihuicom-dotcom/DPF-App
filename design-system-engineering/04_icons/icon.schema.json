{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Financial Icon Registry Schema",
  "type": "object",
  "required": [
    "version",
    "source_policy",
    "taxonomy",
    "token_contract",
    "migration",
    "brand_assets",
    "icons"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "governance_skill": {
      "type": "string"
    },
    "source_policy": {
      "type": "object",
      "required": [
        "primary_library",
        "supplement_libraries",
        "approved_libraries",
        "blocked_libraries",
        "forbidden_sources",
        "runtime_policy"
      ],
      "additionalProperties": true,
      "properties": {
        "primary_library": {
          "const": "phosphor"
        },
        "supplement_libraries": {
          "type": "array",
          "items": {
            "enum": [
              "remix",
              "lucide",
              "iconsax"
            ]
          },
          "minItems": 2
        },
        "custom_policy": {
          "type": "string"
        },
        "approved_libraries": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "object",
            "required": [
              "library",
              "role",
              "package",
              "license",
              "license_url",
              "attribution_required"
            ],
            "additionalProperties": false,
            "properties": {
              "library": {
                "enum": [
                  "phosphor",
                  "remix",
                  "lucide",
                  "iconsax",
                  "custom"
                ]
              },
              "role": {
                "type": "string"
              },
              "package": {
                "type": "string"
              },
              "license": {
                "enum": [
                  "MIT",
                  "Remix Icon License v1.0",
                  "ISC",
                  "Iconsax Free License",
                  "custom-owned"
                ]
              },
              "license_url": {
                "type": "string"
              },
              "attribution_required": {
                "type": "boolean"
              },
              "source_url": {
                "type": "string"
              },
              "source_repository": {
                "type": "string"
              },
              "source_commit": {
                "type": "string"
              }
            }
          }
        },
        "blocked_libraries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "library",
              "reason"
            ],
            "properties": {
              "library": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            }
          }
        },
        "forbidden_sources": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "runtime_policy": {
          "type": "object",
          "required": [
            "delivery",
            "asset_root",
            "renderer",
            "blocked_runtime_dependencies"
          ],
          "additionalProperties": false,
          "properties": {
            "delivery": {
              "const": "local-vendored-assets"
            },
            "asset_root": {
              "const": "src/icons/local"
            },
            "renderer": {
              "const": "src/components/AppIcon.tsx"
            },
            "blocked_runtime_dependencies": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            }
          }
        }
      }
    },
    "taxonomy": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "token_contract": {
      "type": "object",
      "required": [
        "color",
        "size",
        "glyph_size"
      ],
      "properties": {
        "color": {
          "type": "array",
          "items": {
            "pattern": "^color\\.icon\\."
          },
          "minItems": 1
        },
        "size": {
          "type": "array",
          "items": {
            "pattern": "^size\\.icon\\."
          },
          "minItems": 1
        },
        "glyph_size": {
          "type": "array",
          "items": {
            "pattern": "^size\\.iconGlyph\\."
          },
          "minItems": 1
        }
      }
    },
    "migration": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^icon\\.[a-z0-9_]+(\\.[a-z0-9_]+)+$"
      }
    },
    "brand_assets": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "icons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "icon_key",
          "category",
          "meaning",
          "source_library",
          "source_icon_name",
          "style",
          "sizes",
          "default_size",
          "default_canvas_size",
          "default_glyph_size",
          "view_box",
          "safe_area_inset",
          "shape_fit",
          "states",
          "token_binding",
          "usage",
          "platforms",
          "license",
          "modified",
          "status",
          "legacy_names",
          "local_asset_path"
        ],
        "additionalProperties": false,
        "properties": {
          "icon_key": {
            "type": "string",
            "pattern": "^icon\\.[a-z0-9_]+(\\.[a-z0-9_]+)+$"
          },
          "legacy_names": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "category": {
            "type": "string"
          },
          "meaning": {
            "type": "string",
            "minLength": 8
          },
          "source_library": {
            "enum": [
              "phosphor",
              "remix",
              "lucide",
              "iconsax",
              "custom"
            ]
          },
          "source_category": {
            "type": "string"
          },
          "source_category_slug": {
            "type": "string"
          },
          "source_icon_slug": {
            "type": "string"
          },
          "registry_scope": {
            "enum": [
              "semantic",
              "library_asset"
            ]
          },
          "source_icon_name": {
            "type": "string",
            "minLength": 1
          },
          "style": {
            "type": "object",
            "required": [
              "default",
              "active",
              "disabled"
            ],
            "additionalProperties": false,
            "properties": {
              "default": {
                "enum": [
                  "line",
                  "fill",
                  "duotone"
                ]
              },
              "active": {
                "enum": [
                  "line",
                  "fill",
                  "duotone"
                ]
              },
              "disabled": {
                "enum": [
                  "line",
                  "fill",
                  "duotone"
                ]
              }
            }
          },
          "sizes": {
            "type": "array",
            "items": {
              "enum": [
                8,
                12,
                16,
                20,
                24,
                32,
                40,
                48,
                64
              ]
            },
            "minItems": 1
          },
          "default_size": {
            "type": "number"
          },
          "default_canvas_size": {
            "type": "number"
          },
          "default_glyph_size": {
            "type": "number"
          },
          "view_box": {
            "type": "number"
          },
          "safe_area_inset": {
            "type": "number"
          },
          "shape_fit": {
            "enum": [
              "square",
              "rectangle",
              "circle",
              "balanced"
            ]
          },
          "states": {
            "type": "array",
            "items": {
              "enum": [
                "default",
                "active",
                "disabled",
                "success",
                "warning",
                "danger",
                "inverse"
              ]
            },
            "minItems": 1
          },
          "tone_tokens": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "default_tone": {
            "type": "string"
          },
          "token_binding": {
            "type": "object",
            "required": [
              "color",
              "size"
            ],
            "additionalProperties": false,
            "properties": {
              "color": {
                "pattern": "^color\\.icon\\."
              },
              "size": {
                "pattern": "^size\\.icon\\."
              }
            }
          },
          "usage": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "forbidden": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "platforms": {
            "type": "array",
            "items": {
              "enum": [
                "app",
                "h5",
                "web",
                "admin"
              ]
            },
            "minItems": 1
          },
          "license": {
            "type": "object",
            "required": [
              "name",
              "url",
              "attribution_required"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "enum": [
                  "MIT",
                  "Remix Icon License v1.0",
                  "ISC",
                  "Iconsax Free License",
                  "custom-owned"
                ]
              },
              "url": {
                "type": "string"
              },
              "attribution_required": {
                "type": "boolean"
              }
            }
          },
          "modified": {
            "type": "boolean"
          },
          "status": {
            "enum": [
              "draft",
              "approved",
              "deprecated",
              "blocked"
            ]
          },
          "replacement": {
            "type": "string"
          },
          "custom_request": {
            "type": "string"
          },
          "local_asset_path": {
            "type": "string",
            "pattern": "^src/icons/local/(phosphor|lucide|remix|custom)/Local[A-Za-z0-9]+Icon\\.tsx$|^src/icons/local/iconsax/iconsaxGeneratedIcons\\.tsx$"
          }
        }
      }
    }
  }
}
