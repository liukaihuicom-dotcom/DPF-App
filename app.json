{
  "expo": {
    "name": "Dupoin MVP",
    "slug": "dupoin-mvp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/dupoin-logo.png",
    "scheme": "brokerfxmvp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/dupoin-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#31b3bf"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/dupoin-logo.png",
        "backgroundColor": "#31b3bf"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#31b3bf",
          "image": "./assets/images/dupoin-logo.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
